# faster-whisper model size (e.g. base, small, medium, large-v3)
WHISPER_MODEL=base

# CTranslate2 compute type for GPU inference
WHISPER_COMPUTE_TYPE=float16

# Worker subprocess timeout (seconds); default 120 if unset
WORKER_SPAWN_TIMEOUT_SEC=120

# Per-worker override example (alias chinese-hubert-base):
# WORKER_SPAWN_TIMEOUT_CHINESE_HUBERT_BASE=180
